# ---- Jira (required) ----
# Your Atlassian Cloud site, no trailing slash.
JIRA_BASE_URL=https://marianatek.atlassian.net
# The account whose API token is used (must have access to the UTR project).
JIRA_EMAIL=garry.grewal@marianatek.com
# Create at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ---- Webhook auth (recommended) ----
# Shared secret sent by the Jira Automation rule as the `x-webhook-secret` header.
WEBHOOK_SECRET=

# ---- AI (required for complex tags) ----
# Gateway model id (see https://ai-gateway.vercel.sh/v1/models). Must be fast
# enough to finish within the function timeout (60s on the Vercel Hobby plan).
# Recommended: anthropic/claude-sonnet-4.5 (great at SVG, ~7s; needs Gateway
# credits). Free-tier fallbacks: anthropic/claude-3.5-haiku, google/gemini-2.5-flash.
# Avoid heavy reasoning models (gpt-5.x, gemini-2.5-pro) — too slow for 60s.
TAG_AI_MODEL=anthropic/claude-sonnet-4.5
# Auth for the Vercel AI Gateway (set automatically on Vercel; needed locally).
AI_GATEWAY_API_KEY=

# ---- Jira custom field ids (optional) ----
# If your design-request form maps to dedicated fields, set their ids here.
# When unset, values are parsed from the summary/description text instead.
# The UTR "Asset" request form uses these ids:
JIRA_FIELD_TAG_NAME=customfield_10307
JIRA_FIELD_COLOR=customfield_10306
JIRA_FIELD_COUNT=customfield_10416
JIRA_FIELD_DESCRIPTION=
# "Tag Icon" field — a hint for which icon/visual the requester wants.
JIRA_FIELD_ICON=customfield_10309

# ---- Optional behavior ----
# After posting the design-review comment, move the ticket to this status
# (default: In Progress/Review). Resolved via available workflow transitions.
# Set to empty to disable. Override with JIRA_TRANSITION_ID if you know the id.
JIRA_TRANSITION_STATUS=In Progress/Review
JIRA_TRANSITION_ID=
# Restrict the draft comment to a project role (e.g. "Administrators"); omit for normal.
JIRA_COMMENT_VISIBILITY_ROLE=
# Atlassian accountId to @mention in the design-review comment (find via
# atlassianUserInfo or /rest/api/3/myself). Omit to post without a mention.
JIRA_REVIEW_ACCOUNT_ID=
# Optional fallback display text for the mention (e.g. "@Jane Doe").
JIRA_REVIEW_MENTION_TEXT=
# Assignee after automation runs (defaults to JIRA_REVIEW_ACCOUNT_ID when unset).
JIRA_ASSIGNEE_ACCOUNT_ID=
# Additional designers to @mention, comma-separated as accountId:@Display Name.
# Example: 62e93effd49df231b6275f47:@Mackenzie Knight,712020:...@Kendall Jackson
# On initial generation, one designer is chosen at random from this pool plus
# JIRA_REVIEW_ACCOUNT_ID. Regeneration via /regenerate-tag does not @mention anyone.
JIRA_ADDITIONAL_REVIEW_MENTIONS=
# Comma-separated Atlassian accountIds allowed to comment `/regenerate-tag` and
# trigger regeneration. When unset, defaults to JIRA_REVIEW_ACCOUNT_ID,
# JIRA_ADDITIONAL_REVIEW_MENTIONS, and JIRA_ASSIGNEE_ACCOUNT_ID.
JIRA_ALLOWED_REGENERATE_ACCOUNT_IDS=
# Absolute path to the Proxima Nova ExtraBold TTF if not at public/fonts/.
FONT_TTF_PATH=
